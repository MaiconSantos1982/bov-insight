# ============================================
# Worker de Cotações - Variáveis de Ambiente
# ============================================

# --- Supabase (obrigatório para analytics workers) ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SEU_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SCHEMA=public

# --- Analytics Sources (JSON arrays) ---
# Cada endpoint deve retornar array no formato esperado pelo worker.
# Para ciclo: provider default = sidra (tabela 1092). Use "file" para fallback local.
ANALYTICS_CICLO_PROVIDER=sidra
ANALYTICS_CICLO_URL=
ANALYTICS_BASE_REGIONAL_PROVIDER=derived
ANALYTICS_BASE_REGIONAL_SPREADS=GOIANIA:-5.5,DOURADOS:-5.0
ANALYTICS_BASE_REGIONAL_URL=
ANALYTICS_ESCALA_PROVIDER=operacional
ANALYTICS_ESCALA_ABATE_URL=
ANALYTICS_EXPORTACAO_URL=
ANALYTICS_EXPORTACAO_PROVIDER=secex
ANALYTICS_EXPORTACAO_CHINA_COUNTRY_CODE=160
ANALYTICS_EXPORTACAO_NCM_PREFIXES=0201,0202,0206
ANALYTICS_ALERT_CHINA_THRESHOLD_PCT=70
# Exemplo: a cada 30 min
ANALYTICS_ALERT_CRON=*/30 * * * *
# Exemplo recomendado: diário às 08:00 (histórico), separado do envio de grupo
ANALYTICS_INGEST_CRON=0 8 * * *
# Janela retroativa de processamento por módulo (meses)
ANALYTICS_CICLO_LOOKBACK_MONTHS=24
ANALYTICS_BASE_LOOKBACK_MONTHS=6
ANALYTICS_ESCALA_LOOKBACK_MONTHS=3
ANALYTICS_EXPORTACAO_LOOKBACK_MONTHS=24

# --- Pastorini API (WhatsApp) ---
PASTORINI_BASE_URL=https://papi.superadesafio.com.br
PASTORINI_API_KEY=SEU_PASTORINI_API_KEY
PASTORINI_INSTANCE=maicon_teste
#PASTORINI_ID=maicon_teste


# --- WhatsApp Group ID ---
# Formato: 123456789-123456@g.us
WHATSAPP_GROUP_ID=ID_DO_GRUPO_AQUI

# --- Cron Schedule ---
# Exemplo recomendado: envio principal do grupo às 08:30
CRON_SCHEDULE=30 8 * * *

# --- Modo de Execução ---
# headless: true = sem interface gráfica (produção)
# headless: false = com interface gráfica (debug)
HEADLESS=true

# --- Segurança de Execução Remota ---
# Se definido, /api/executar exigirá token válido:
#   Authorization: Bearer <token>
# ou header x-exec-token
# ou query ?token=<token>
EXEC_TOKEN=SEU_TOKEN_DE_EXECUCAO
